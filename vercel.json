{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/walkthrough", "destination": "/index.html" },
    { "source": "/weapons", "destination": "/index.html" },
    { "source": "/postgame", "destination": "/index.html" }
  ],
  "redirects": [],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
